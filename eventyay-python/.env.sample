# Old eventyay API JWT. Keep the `JWT ` prefix.
EVENTYAY_JWT="JWT replace-me"

# New local eventyay API token. Raw token or `Token ...` both work.
OPENEVENT_AUTH_TOKEN="replace-me"

# Optional: attendee/order validation in the old API is flaky and disabled by default.
# ENABLE_TICKET_SALES_VALIDATION="false"
